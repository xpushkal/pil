# Copy to .env and fill in. Do not commit .env.
# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
PIL_ENV=local
PIL_LOG_LEVEL=INFO
PIL_HOST=0.0.0.0
PIL_PORT=8000

# Comma-separated list of trusted client origins for CORS (empty disables CORS).
PIL_CORS_ORIGINS=

# ----------------------------------------------------------------------------
# Database (Postgres + pgvector)
# ----------------------------------------------------------------------------
PIL_DATABASE_URL=postgresql+asyncpg://pil:pil@postgres:5432/pil
PIL_DATABASE_URL_SYNC=postgresql+psycopg://pil:pil@postgres:5432/pil

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
PIL_REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
PIL_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PIL_OTEL_SERVICE_NAME=pil-api
PIL_PROMETHEUS_ENABLED=true

# ----------------------------------------------------------------------------
# Sprint 1: PII scrubber + semantic cache (used in Phase 2)
# ----------------------------------------------------------------------------
PIL_PII_MODE=reversible            # reversible | one_way
PIL_PII_MAP_TTL_SECONDS=300
PIL_PII_FAIL_CLOSED=true

PIL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PIL_EMBEDDING_DEVICE=auto          # auto | cpu | mps | cuda
PIL_CACHE_SIMILARITY_THRESHOLD=0.92
PIL_CACHE_TTL_SECONDS=86400

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
PIL_DEFAULT_RATE_LIMIT_PER_HOUR=1000
PIL_KEY_ROTATION_GRACE_HOURS=24

# ----------------------------------------------------------------------------
# Encryption (per-org keys live in DB; this is the master key for envelope encryption of raw payloads)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ----------------------------------------------------------------------------
PIL_MASTER_ENCRYPTION_KEY=change-me-to-a-32-byte-urlsafe-string

# ----------------------------------------------------------------------------
# Upstream providers (PIL never stores these; values here only used in integration tests)
# ----------------------------------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
